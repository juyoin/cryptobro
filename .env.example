# Core
PYTHON_VERSION=3.12

# Simulation mode toggle (must remain true for this project)
SIMULATION_MODE=true

# Market data
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=

# AI providers
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=
GROQ_API_KEY=

# Optional model defaults
GEMINI_MODEL=gemini-2.0-flash
HUGGINGFACE_MODEL=google/gemma-2-2b-it
PRIMARY_MODEL=gemini/gemini-2.0-flash
SECONDARY_MODEL=huggingface/google/gemma-2-2b-it

# App settings
REFRESH_SECONDS=30
LOG_LEVEL=INFO
